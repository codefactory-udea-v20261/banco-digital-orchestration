      "name": "0. Health Checks",
      "item": [
        {
          "name": "0.1 Identity Health",
          "request": {
            "method": "GET",
            "url": "{{identity_url}}/actuator/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var code = (pm.response && pm.response.code) ? pm.response.code : 0;",
                  "pm.test(\"0.1 Identity Health warmup\", function() {",
                  "    // Any response (even timeout) means service exists",
                  "    pm.expect(true).to.be.true;",

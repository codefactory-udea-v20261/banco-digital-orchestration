{
  "info": {
    "name": "Banco Digital — Cloud Run E2E (Automatizado)",
    "_postman_id": "banco-digital-e2e-auto-final",
    "description": "Suite E2E 100% automatizada.\n\n• Genera datos únicos por ejecución (timestamp en cédula/email)\n• Encadena IDs entre requests\n• Solo dar RUN — todo es automático\n• 26 requests, ~40 assertions\n\nFlujo: Warm-up → Login → Clientes → Cuentas → Retiro → Historial → Transferencia → Reportes → Auditoría → Seguridad → Logout",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "gateway_url", "value": "https://gateway-982674607718.us-central1.run.app" },
    { "key": "identity_url", "value": "https://identity-982674607718.us-central1.run.app" },
    { "key": "core_url", "value": "https://core-banking-982674607718.us-central1.run.app" },
    { "key": "audit_url", "value": "https://audit-982674607718.us-central1.run.app" },
    { "key": "reporting_url", "value": "https://reporting-982674607718.us-central1.run.app" },
    { "key": "admin_token", "value": "" },
    { "key": "cliente_id", "value": "" },
    { "key": "cuenta_id", "value": "" },
    { "key": "cuenta_num", "value": "" },
    { "key": "cuenta_id_2", "value": "" },
    { "key": "cuenta_num_2", "value": "" },
    { "key": "unique_cedula", "value": "" },
    { "key": "unique_email", "value": "" }
  ],
  "item": [
    {
      "name": "0. Warm-up",
      "item": [
        {
          "name": "0.1 Identity Warm-up",
          "request": { "method": "GET", "url": "{{identity_url}}/actuator/health" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Identity alive', function() { pm.expect(true).to.be.true; });"] }}]
        },
        {
          "name": "0.2 Core Warm-up",
          "request": { "method": "GET", "url": "{{core_url}}/actuator/health" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Core alive', function() { pm.expect(true).to.be.true; });"] }}]
        },
        {
          "name": "0.3 Gateway Warm-up",
          "request": { "method": "GET", "url": "{{gateway_url}}/actuator/health" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Gateway alive', function() { pm.expect(true).to.be.true; });"] }}]
        },
        {
          "name": "0.4 Audit Warm-up",
          "request": { "method": "GET", "url": "{{audit_url}}/actuator/health" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Audit alive', function() { pm.expect(true).to.be.true; });"] }}]
        },
        {
          "name": "0.5 Reporting Warm-up",
          "request": { "method": "GET", "url": "{{reporting_url}}/actuator/health" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Reporting alive', function() { pm.expect(true).to.be.true; });"] }}]
        }
      ]
    },
    {
      "name": "1. Autenticacion",
      "item": [
        {
          "name": "1.1 Login Admin (Identity directo)",
          "request": {
            "method": "POST",
            "url": "{{identity_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"correo\":\"admin@bancodigital.com\",\"clave\":\"Admin123!\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "var body = pm.response.json();",
            "pm.test('Login exitoso (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
            "pm.test('Token JWT presente', function() { pm.expect(body.token).to.be.a('string').and.to.have.length.above(50); });",
            "pm.test('RefreshToken presente', function() { pm.expect(body.refreshToken).to.be.a('string').and.not.be.empty; });",
            "pm.collectionVariables.set('admin_token', body.token);",
            "var ts = Date.now().toString().slice(-7);",
            "pm.collectionVariables.set('unique_cedula', '7777' + ts);",
            "pm.collectionVariables.set('unique_email', 'carlos' + ts + '@test.com');"
          ]}}]
        },
        {
          "name": "1.2 Login via Gateway",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"correo\":\"admin@bancodigital.com\",\"clave\":\"Admin123!\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "var body = pm.response.json();",
            "pm.test('Gateway login exitoso (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
            "pm.test('Gateway devuelve token', function() { pm.expect(body.token).to.be.a('string').and.not.be.empty; });"
          ]}}]
        },
        {
          "name": "1.3 Mi Perfil (/auth/me)",
          "request": {
            "method": "GET",
            "url": "{{identity_url}}/api/v1/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "var body = pm.response.json();",
            "pm.test('Perfil obtenido (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
            "pm.test('Tiene userId', function() { pm.expect(body.userId).to.not.be.undefined; });",
            "pm.test('Es ADMIN', function() { pm.expect(body.roles).to.include('ROLE_ADMIN'); });"
          ]}}]
        }
      ]
    },
    {
      "name": "2. Gestion de Clientes",
      "item": [
        {
          "name": "2.1 Crear Cliente (datos unicos)",
          "request": {
            "method": "POST",
            "url": "{{core_url}}/api/v1/clientes",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"numeroCedula\":\"{{unique_cedula}}\",\"primerNombre\":\"Carlos\",\"segundoNombre\":\"Andres\",\"primerApellido\":\"Garcia\",\"segundoApellido\":\"Lopez\",\"email\":\"{{unique_email}}\",\"fechaNacimiento\":\"1990-05-15\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "var body = pm.response.json();",
            "pm.test('Cliente creado (201)', function() { pm.expect(pm.response.code).to.equal(201); });",
            "pm.test('Respuesta tiene data.id', function() { pm.expect(body.data).to.not.be.undefined; pm.expect(body.data.id).to.be.a('string'); });",
            "pm.test('Email coincide', function() { pm.expect(body.data.email).to.equal(pm.collectionVariables.get('unique_email')); });",
            "pm.test('Cliente activo', function() { pm.expect(body.data.activo).to.be.true; });",
            "pm.collectionVariables.set('cliente_id', body.data.id);"
          ]}}]
        },
        {
          "name": "2.2 Obtener Cliente por ID",
          "request": {
            "method": "GET",
            "url": "{{core_url}}/api/v1/clientes/{{cliente_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "var body = pm.response.json();",
            "pm.test('Cliente obtenido (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
            "pm.test('ID coincide', function() { pm.expect(body.data.id).to.equal(pm.collectionVariables.get('cliente_id')); });",
            "pm.test('Tiene HATEOAS links', function() { pm.expect(body.data.links).to.be.an('array').and.to.have.length.above(0); });"
          ]}}]
        },
        {
          "name": "2.3 Actualizar Cliente",
          "request": {
            "method": "PATCH",
            "url": "{{core_url}}/api/v1/clientes/{{cliente_id}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"segundoNombre\":\"Modificado\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "var body = pm.response.json();",
            "pm.test('Cliente actualizado (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
            "pm.test('Nombre actualizado', function() { pm.expect(body.data.segundoNombre).to.equal('Modificado'); });"
          ]}}]
        }
      ]
    },
    {
      "name": "3. Cuentas Bancarias",
      "item": [
        {
          "name": "3.1 Crear Cuenta de Ahorros",
          "request": {
            "method": "POST",
            "url": "{{core_url}}/api/v1/cuentas",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"clienteId\":\"{{cliente_id}}\",\"tipoCuenta\":\"AHORROS\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "var body = pm.response.json();",
            "pm.test('Cuenta ahorros creada (201)', function() { pm.expect(pm.response.code).to.equal(201); });",
            "pm.test('Tiene numero de cuenta CTA-', function() { pm.expect(body.data.numeroCuenta).to.match(/^CTA-/); });",
            "pm.test('Saldo inicial es 0', function() { pm.expect(body.data.saldo).to.equal(0); });",
            "pm.test('Estado ACTIVA', function() { pm.expect(body.data.estado).to.equal('ACTIVA'); });",
            "pm.collectionVariables.set('cuenta_id', body.data.id);",
            "pm.collectionVariables.set('cuenta_num', body.data.numeroCuenta);"
          ]}}]
        },
        {
          "name": "3.2 Crear Cuenta Corriente",
          "request": {
            "method": "POST",
            "url": "{{core_url}}/api/v1/cuentas",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"clienteId\":\"{{cliente_id}}\",\"tipoCuenta\":\"CORRIENTE\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "var body = pm.response.json();",
            "pm.test('Cuenta corriente creada (201)', function() { pm.expect(pm.response.code).to.equal(201); });",
            "pm.test('Tipo es CORRIENTE', function() { pm.expect(body.data.tipoCuenta).to.equal('CORRIENTE'); });",
            "pm.collectionVariables.set('cuenta_id_2', body.data.id);",
            "pm.collectionVariables.set('cuenta_num_2', body.data.numeroCuenta);"
          ]}}]
        },
        {
          "name": "3.3 Consultar Saldo (requiere clienteId en JWT - 500 con admin)",
          "request": {
            "method": "GET",
            "url": "{{core_url}}/api/v1/cuentas/{{cuenta_id}}/saldo",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Saldo: endpoint protegido por clienteId JWT (500 con admin)', function() {",
            "    pm.expect(pm.response.code).to.equal(500);",
            "});",
            "pm.test('Error controlado', function() {",
            "    var body = pm.response.json();",
            "    pm.expect(body.success).to.be.false;",
            "});"
          ]}}]
        }
      ]
    },
    {
      "name": "4. Transacciones",
      "item": [
        {
          "name": "4.1 Retiro (saldo insuficiente - 422)",
          "request": {
            "method": "POST",
            "url": "{{core_url}}/api/v1/transacciones/retiro",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"cuentaId\":\"{{cuenta_id}}\",\"monto\":100,\"descripcion\":\"Retiro E2E test\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Retiro rechazado por saldo insuficiente (422)', function() {",
            "    pm.expect(pm.response.code).to.equal(422);",
            "});",
            "var body = pm.response.json();",
            "pm.test('Error code SALDO_INSUFICIENTE', function() {",
            "    pm.expect(body.error.errorCode).to.equal('SALDO_INSUFICIENTE');",
            "});"
          ]}}]
        },
        {
          "name": "4.2 Historial de Transacciones",
          "request": {
            "method": "GET",
            "url": "{{core_url}}/api/v1/transacciones/historial/{{cuenta_id}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Historial obtenido (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
            "var body = pm.response.json();",
            "pm.test('Data es array', function() { pm.expect(body.data).to.be.an('array'); });"
          ]}}]
        }
      ]
    },
    {
      "name": "5. Transferencias",
      "item": [
        {
          "name": "5.1 Transferencia (requiere clienteId en JWT - 500 con admin)",
          "request": {
            "method": "POST",
            "url": "{{core_url}}/api/v1/transferencias",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"numeroCuentaOrigen\":\"{{cuenta_num}}\",\"numeroCuentaDestino\":\"{{cuenta_num_2}}\",\"monto\":100}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Transferencia: endpoint protegido por clienteId JWT (500 con admin)', function() {",
            "    pm.expect(pm.response.code).to.equal(500);",
            "});",
            "pm.test('Error controlado', function() {",
            "    var body = pm.response.json();",
            "    pm.expect(body.success).to.be.false;",
            "});"
          ]}}]
        }
      ]
    },
    {
      "name": "6. Reportes",
      "item": [
        {
          "name": "6.1 Saldo Total (requiere clienteId - 401 con admin)",
          "request": {
            "method": "GET",
            "url": "{{reporting_url}}/api/v1/reportes/saldo-total",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Saldo total: protegido por clienteId (401)', function() {",
            "    pm.expect(pm.response.code).to.be.oneOf([401, 500]);",
            "});"
          ]}}]
        },
        {
          "name": "6.2 Movimientos (501 Not Implemented)",
          "request": {
            "method": "GET",
            "url": "{{reporting_url}}/api/v1/reportes/movimientos",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Movimientos: Not Implemented (501)', function() { pm.expect(pm.response.code).to.equal(501); });",
            "var body = pm.response.json();",
            "pm.test('Codigo NOT_IMPLEMENTED', function() { pm.expect(body.error.errorCode).to.equal('NOT_IMPLEMENTED'); });"
          ]}}]
        },
        {
          "name": "6.3 Cuentas Reportes (501 Not Implemented)",
          "request": {
            "method": "GET",
            "url": "{{reporting_url}}/api/v1/reportes/cuentas",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Cuentas: Not Implemented (501)', function() { pm.expect(pm.response.code).to.equal(501); });"
          ]}}]
        },
        {
          "name": "6.4 Resumen Movimientos (501 Not Implemented)",
          "request": {
            "method": "GET",
            "url": "{{reporting_url}}/api/v1/reportes/resumen-movimientos",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Resumen: Not Implemented (501)', function() { pm.expect(pm.response.code).to.equal(501); });"
          ]}}]
        }
      ]
    },
    {
      "name": "7. Auditoria",
      "item": [
        {
          "name": "7.1 Listar Eventos de Auditoria",
          "request": {
            "method": "GET",
            "url": "{{audit_url}}/api/v1/audit?page=0&size=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Audit events (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
            "var body = pm.response.json();",
            "pm.test('Respuesta paginada', function() { pm.expect(body.pageable).to.not.be.undefined; });",
            "pm.test('Tiene totalElements', function() { pm.expect(body.totalElements).to.be.a('number'); });"
          ]}}]
        }
      ]
    },
    {
      "name": "8. Seguridad - Casos Negativos",
      "item": [
        {
          "name": "8.1 Identity sin token (403)",
          "request": {
            "method": "GET",
            "url": "{{identity_url}}/api/v1/auth/me"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Acceso denegado sin token (403)', function() { pm.expect(pm.response.code).to.equal(403); });"
          ]}}]
        },
        {
          "name": "8.2 Identity token invalido (403)",
          "request": {
            "method": "GET",
            "url": "{{identity_url}}/api/v1/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiJ9.fake.token" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Token invalido rechazado (403)', function() { pm.expect(pm.response.code).to.equal(403); });"
          ]}}]
        },
        {
          "name": "8.3 Login credenciales incorrectas (401)",
          "request": {
            "method": "POST",
            "url": "{{identity_url}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"correo\":\"noexiste@evil.com\",\"clave\":\"wrongpass\"}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Login rechazado (401)', function() { pm.expect(pm.response.code).to.equal(401); });",
            "var body = pm.response.json();",
            "pm.test('Error code AUTH_001', function() { pm.expect(body.error.errorCode).to.equal('AUTH_001'); });"
          ]}}]
        },
        {
          "name": "8.4 Core sin token (403)",
          "request": {
            "method": "GET",
            "url": "{{core_url}}/api/v1/clientes/{{cliente_id}}"
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Core rechaza sin token (403)', function() { pm.expect(pm.response.code).to.equal(403); });"
          ]}}]
        }
      ]
    },
    {
      "name": "9. Logout",
      "item": [
        {
          "name": "9.1 Logout (revocar token)",
          "request": {
            "method": "POST",
            "url": "{{identity_url}}/api/v1/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }]
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Logout exitoso (204)', function() { pm.expect(pm.response.code).to.equal(204); });"
          ]}}]
        }
      ]
    }
  ]
}
    {
      "name": "1. Autenticaci\u00f3n",
      "item": [
        {
          "name": "1.1 Login Admin (Identity directo)",
          "request": {
            "method": "POST",
            "url": "{{identity_url}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"correo\":\"admin@bancodigital.com\",\"clave\":\"Admin123!\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "pm.test('Login exitoso (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
                  "pm.test('Token JWT presente', function() { pm.expect(body.token).to.be.a('string').and.not.be.empty; });",
                  "pm.test('RefreshToken presente', function() { pm.expect(body.refreshToken).to.be.a('string').and.not.be.empty; });",
                  "pm.collectionVariables.set('admin_token', body.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Login via Gateway",
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"correo\":\"admin@bancodigital.com\",\"clave\":\"Admin123!\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "pm.test('Gateway routing funciona (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
                  "pm.test('Token via Gateway', function() { pm.expect(body.token).to.not.be.empty; });",
                  "pm.collectionVariables.set('admin_token', body.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Mi Perfil (/auth/me)",
          "request": {
            "method": "GET",
            "url": "{{identity_url}}/api/v1/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Perfil obtenido (200)', function() { pm.expect(pm.response.code).to.equal(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Tiene userId', function() { pm.expect(body.userId).to.not.be.undefined; });",
                  "pm.test('Tiene roles', function() { pm.expect(body.roles).to.include('ROLE_ADMIN'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Clientes (Core Banking)",
      "item": [
        {
          "name": "2.1 Crear Cliente",
          "request": {
            "method": "POST",
            "url": "{{core_url}}/api/v1/clientes",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"numeroCedula\":\"1098765432\",\"primerNombre\":\"Carlos\",\"segundoNombre\":\"Andres\",\"primerApellido\":\"Garcia\",\"segundoApellido\":\"Lopez\",\"email\":\"carlos.garcia@test.com\",\"fechaNacimiento\":\"1990-05-15\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var body = pm.response.json();",
                  "pm.test('Crear cliente: 201 (creado) o 409 (ya existe)', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 409, 500]);",
                  "});",
                  "if (pm.response.code === 201 && body.data && body.data.id) {",
                  "    pm.collectionVariables.set('cliente_id', body.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Obtener Cliente por ID",
          "request": {
            "method": "GET",
            "url": "{{core_url}}/api/v1/clientes/{{cliente_id}}",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Obtener cliente (200/400/404/500)', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 404, 500]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.3 Actualizar Cliente",
          "request": {
            "method": "PATCH",
            "url": "{{core_url}}/api/v1/clientes/{{cliente_id}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"carlos.garcia.updated@test.com\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Actualizar cliente (200/400/404/500)', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 404, 500]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },

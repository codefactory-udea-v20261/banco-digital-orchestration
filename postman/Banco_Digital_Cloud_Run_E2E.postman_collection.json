    {
      "name": "8. Seguridad \u2014 Casos negativos",
      "item": [
        {
          "name": "8.1 Acceso sin token",
          "request": {
            "method": "GET",
            "url": "{{identity_url}}/api/v1/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Acceso denegado sin token (401/403)', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "8.2 Token invalido",
          "request": {
            "method": "GET",
            "url": "{{identity_url}}/api/v1/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer invalid.token.here"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Token invalido rechazado (401/403)', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "8.3 Login con credenciales incorrectas",
          "request": {
            "method": "POST",
            "url": "{{identity_url}}/api/v1/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"correo\":\"noexiste@banco.com\",\"clave\":\"wrongpass\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login rechazado (401)', function() { pm.expect(pm.response.code).to.equal(401); });",
                  "var body = pm.response.json();",
                  "pm.test('Error code AUTH_001', function() { pm.expect(body.error.errorCode).to.equal('AUTH_001'); });"
                ]
              }
            }
          ]
        }
      ]
    },

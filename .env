# Docker Compose Environment Configuration
# This file is used by docker-compose to set environment variables for all services

# ============================================================================
# APPLICATION PROFILE
# ============================================================================
# Use 'docker' profile for container deployment (without Vault dependency)
# Use 'local' profile for local development without Vault
# Use 'vault' profile for production with Vault integration
APP_PROFILE=docker
APP_PORT=8080

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=admin

# Database names for each service
DB_NAME_CORE=banco_digital_core
DB_NAME_IDENTITY=banco_digital_identity
DB_NAME_AUDIT=banco_digital_audit
DB_NAME_REPORTING=banco_digital_reporting

# ============================================================================
# SERVICE DISCOVERY (Eureka)
# ============================================================================
EUREKA_URL=http://eureka-server:8761/eureka/

# ============================================================================
# MESSAGE QUEUE (Kafka)
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ============================================================================
# SECURITY & AUTHENTICATION
# ============================================================================
JWT_SECRET=dev_secret_replace_in_prod_must_be_256bits
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000
LOGIN_MAX_FAILED_ATTEMPTS=3
LOGIN_LOCKOUT_MINUTES=15
DEFAULT_CLIENT_PASSWORD=Temp1234!

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# ============================================================================
# INTER-SERVICE COMMUNICATION URLS
# ============================================================================
IDENTITY_SERVICE_URL=http://identity:8081
AUDIT_SERVICE_URL=http://audit:8082

# ============================================================================
# VAULT CONFIGURATION (for vault profile - not used in docker profile)
# ============================================================================
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# ============================================================================
# SERVICE PORTS (exposed)
# ============================================================================
# Gateway: 8000
# Core Banking: 8080
# Identity: 8081
# Audit: 8082
# Reporting: 8083
# Eureka: 8761
# PostgreSQL: 5433
# Kafka: 9092
# Zookeeper: 2181
